@page "/"
@using MudBlazor
@inject NavigationManager NavigationManager

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-5">
    <MudText Typo="Typo.h3" Align="Align.Center">Welcome to the Password Game!</MudText>
    <MudText Typo="Typo.body1" Align="Align.Center" Class="mt-3">
        Test your password strength and learn how to create stronger passwords.
    </MudText>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="mt-4" OnClick="@StartGame">
        Start Playing
    </MudButton>
</MudContainer>


@code {
    private void StartGame()
    {
        // Navigate to the game page
        NavigationManager.NavigateTo("/game");
    }
}